<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.4.4</version>
        <relativePath/> <!-- lookup parent from repository -->
    </parent>

    <groupId>com.bajins.ocr</groupId>
    <artifactId>ocr-springboot-demo</artifactId>
    <version>1.0-SNAPSHOT</version>

    <description>ocr使用示例</description>

    <properties>
        <maven.compiler.source>25</maven.compiler.source>
        <maven.compiler.target>25</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <smartjavaai.version>1.1.2</smartjavaai.version>
        <javacpp.platform>linux-x86_64</javacpp.platform> <!-- 或 windows-x86_64, macosx-x86_64, macosx-arm64 -->
        <javacv.version>1.5.10</javacv.version>
        <javacv.ffmpeg.version>6.1.1-1.5.10</javacv.ffmpeg.version>
        <javacv.openblas.version>0.3.26-1.5.10</javacv.openblas.version>
        <javacv.opencv.version>4.9.0-1.5.10</javacv.opencv.version>
        <javacv.platform.macosx-arm64>macosx-arm64</javacv.platform.macosx-arm64>
        <javacv.platform.linux-x86_64>linux-x86_64</javacv.platform.linux-x86_64>
        <javacv.platform.linux-arm64>linux-arm64</javacv.platform.linux-arm64>
        <javacv.platform.windows-x86_64>windows-x86_64</javacv.platform.windows-x86_64>
        <djl.pytorch.version>2.7.1</djl.pytorch.version>
        <djl.platform.windows-x86_64>win-x86_64</djl.platform.windows-x86_64>
        <djl.platform.linux-x86_64>linux-x86_64</djl.platform.linux-x86_64>
        <djl.platform.linux-aarch64>linux-aarch64</djl.platform.linux-aarch64>
        <djl.platform.osx-aarch64>osx-aarch64</djl.platform.osx-aarch64>
        <zxing.version>3.5.4</zxing.version>
        <boofcv.version>1.4.0</boofcv.version>
        <boofcv.visualize.version>0.26</boofcv.visualize.version>
    </properties>

    <!--  打包命令：mvn clean package -P linux-x86_64 -Dlinux-build  -->
    <profiles>
        <profile>
            <id>linux-x86_64</id>
            <activation>
                <os>
                    <family>unix</family>
                    <arch>amd64</arch>
                </os>
            </activation>
            <dependencies>
                <!-- https://mvnrepository.com/artifact/io.github.mymonstercat/rapidocr-onnx-linux-x86_64 -->
                <!--<dependency>-->
                <!--    <groupId>io.github.mymonstercat</groupId>-->
                <!--    <artifactId>rapidocr-onnx-linux-x86_64</artifactId>-->
                <!--    <version>1.2.2</version>-->
                <!--</dependency>-->
            </dependencies>
        </profile>
        <profile>
            <id>windows-x86_64</id>
            <activation>
                <os>
                    <family>windows</family>
                    <arch>amd64</arch>
                </os>
            </activation>
            <dependencies>
                <!-- https://mvnrepository.com/artifact/io.github.mymonstercat/rapidocr-onnx-linux-x86_64 -->
                <dependency>
                    <groupId>io.github.mymonstercat</groupId>
                    <artifactId>rapidocr-onnx-windows-x86_64</artifactId>
                    <version>1.2.2</version>
                </dependency>
            </dependencies>
        </profile>
    </profiles>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>cn.smartjavaai</groupId>
                <artifactId>bom</artifactId>
                <version>${smartjavaai.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <version>1.18.46</version>
            <scope>provided</scope>
        </dependency>

        <!-- ========================== https://github.com/MyMonsterCat/RapidOcr-Java =========================== -->

        <!-- https://mvnrepository.com/artifact/io.github.mymonstercat/rapidocr -->
        <dependency>
            <groupId>io.github.mymonstercat</groupId>
            <artifactId>rapidocr</artifactId>
            <version>0.0.7</version>
            <exclusions>
                <exclusion>
                    <artifactId>slf4j-api</artifactId>
                    <groupId>org.slf4j</groupId>
                </exclusion>
            </exclusions>
        </dependency>
        <!-- https://mvnrepository.com/artifact/io.github.mymonstercat/rapidocr-onnx-platform -->
        <dependency>
            <groupId>io.github.mymonstercat</groupId>
            <artifactId>rapidocr-onnx-platform</artifactId>
            <version>0.0.7</version>
        </dependency>
        <!-- ========================== RapidOcr-Java end =========================== -->

        <!-- ========================== https://github.com/geekwenjie/SmartJavaAI =========================== -->
        <dependency>
            <groupId>cn.smartjavaai</groupId>
            <artifactId>ocr</artifactId>
            <version>${smartjavaai.version}</version>
            <exclusions>
                <exclusion>
                    <groupId>com.microsoft.onnxruntime</groupId>
                    <artifactId>onnxruntime</artifactId>
                </exclusion>
            </exclusions>
        </dependency>

        <!-- OnnxRuntime离线平台依赖 -->
        <dependency>
            <groupId>com.microsoft.onnxruntime</groupId>
            <artifactId>onnxruntime</artifactId>
            <version>1.20.0</version>
            <scope>runtime</scope>
        </dependency>

        <!--PyTorch离线平台依赖 pytorch-native-cpu -->
        <dependency>
            <groupId>ai.djl.pytorch</groupId>
            <artifactId>pytorch-jni</artifactId>
            <version>2.7.1-0.34.0</version>
            <scope>runtime</scope>
        </dependency>

        <!-- tensorflow离线平台依赖 -->
        <dependency>
            <groupId>ai.djl.tensorflow</groupId>
            <artifactId>tensorflow-native-cpu</artifactId>
            <classifier>${djl.platform.windows-x86_64}</classifier>
            <scope>runtime</scope>
            <version>2.16.1</version>
        </dependency>

        <!-- mxnet离线平台依赖 -->
        <dependency>
            <groupId>ai.djl.mxnet</groupId>
            <artifactId>mxnet-native-mkl</artifactId>
            <classifier>${djl.platform.windows-x86_64}</classifier>
            <scope>runtime</scope>
            <version>1.9.1</version>
        </dependency>
        <!-- ========================== SmartJavaAI end =========================== -->

        <!-- +++++++++++++++++++++++++++++++++++++ OpenCV 用于图像预处理 start +++++++++++++++++++++++++++++++++++++ -->
