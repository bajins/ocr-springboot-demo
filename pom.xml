            <version>4.13.0</version>
            <scope>runtime</scope>
        </dependency>-->
        <!-- Source: https://mvnrepository.com/artifact/org.openpnp/opencv -->
        <dependency>
            <groupId>org.openpnp</groupId>
            <artifactId>opencv</artifactId>
            <version>4.9.0-0</version>
            <scope>compile</scope>
        </dependency>
        <!-- https://github.com/openpnp/opencv -->
        <!-- https://github.com/julienmerconsulting/Apertix -->
        <!-- Source: https://mvnrepository.com/artifact/io.github.julienmerconsulting.apertix/opencv -->
