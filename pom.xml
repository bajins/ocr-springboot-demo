            <version>${djl.pytorch.version}</version>
            <scope>runtime</scope>
        </dependency>
        <!-- ========================== djl end =========================== -->

        <!-- ========================== https://github.com/bytedeco/javacpp-presets/tree/master/tesseract =========================== -->
        <!-- https://mvnrepository.com/artifact/org.bytedeco/tesseract-platform -->
