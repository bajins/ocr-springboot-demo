            <groupId>ai.djl.pytorch</groupId>
            <artifactId>pytorch-native-cpu</artifactId>
            <classifier>${djl.platform.linux-aarch64}</classifier>
            <version>${djl.pytorch.version}</version>
            <scope>runtime</scope>
        </dependency>
        <!-- macOS M系列 平台  (保留对应平台的配置，可以减小包大小)-->
